# Copy this file to `.env` (in the same folder) and fill in your values.
# `start.ps1` loads it automatically.
# DO NOT COMMIT YOUR REAL .env FILE - it's already in .gitignore.

# --- Twilio (for real phone calls) -------------------------------------------
# Find your Auth Token at: https://console.twilio.com/  (Account Info -> Auth Token)
TWILIO_AUTH_TOKEN=

# Optional: voice + language. See https://www.twilio.com/docs/voice/twiml/say/text-speech
TWILIO_VOICE=Polly.Joanna
TWILIO_LANGUAGE=en-US
TWILIO_GATHER_TIMEOUT=5

# Override the greeting / goodbye lines if you like
# TWILIO_GREETING=Hi! How can I help today?
# TWILIO_GOODBYE=Thanks for calling. Goodbye!

# --- Telegram (optional) -----------------------------------------------------
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# --- Ollama (optional) -------------------------------------------------------
# Defaults are usually fine if Ollama is running locally on the same machine.
# OLLAMA_URL=http://localhost:11434/api/generate
# OLLAMA_MODEL=llama3.2:3b
# OLLAMA_TIMEOUT=30
